{
  "[development]": {
    "auth": {
      "kind": "dummy",
      "users": {
        "alice": {
          "roles": ["AdminAccess", "FuelOrderCreate", "FuelOrderApprove", "ePODCapture", "ePODApprove", "InvoiceVerify", "InvoiceApprove", "FinancePost", "MasterDataAdmin", "MasterDataRead", "MasterDataWrite", "ContractManage", "PlanningAccess", "ReportView", "IntegrationMonitor", "BurnDataEdit"],
          "attributes": {
            "station": ["*"],
            "region": ["*"]
          }
        },
        "kalpesh": {
          "roles": ["AdminAccess", "FuelOrderCreate", "FuelOrderApprove", "ePODCapture", "ePODApprove", "InvoiceVerify", "InvoiceApprove", "FinancePost", "MasterDataAdmin", "MasterDataRead", "MasterDataWrite", "ContractManage", "PlanningAccess", "ReportView", "IntegrationMonitor", "BurnDataEdit"],
          "attributes": {
            "station": ["*"],
            "region": ["*"]
          }
        },
        "planner": {
          "roles": ["FuelPlanner", "MasterDataRead", "FuelOrderCreate", "PlanningAccess", "ReportView"],
          "attributes": {
            "station": ["*"],
            "region": ["*"]
          }
        },
        "dispatch": {
          "roles": ["DispatchTeam", "MasterDataRead", "FuelOrderCreate", "PlanningAccess", "BurnDataView"],
          "attributes": {
            "station": ["YYZ", "YVR", "LHR"],
            "region": ["NAM", "EUR"]
          }
        },
        "cockpit": {
          "roles": ["CockpitCrew", "MasterDataRead", "FuelOrderCreate", "BurnDataView"],
          "attributes": {
            "station": ["*"],
            "region": ["*"]
          }
        },
        "ops": {
          "roles": ["OperationsManager", "StationCoordinator", "MasterDataRead", "BurnDataView", "BurnDataEdit", "FuelOrderApprove", "ePODApprove", "ReportView"],
          "attributes": {
            "station": ["MNL", "CEB", "YYZ", "YVR"],
            "region": ["APAC", "NAM"]
          }
        },
        "supplier": {
          "roles": ["SupplierPlanner", "MasterDataRead", "FuelOrderApprove", "ReportView"],
          "attributes": {
            "station": ["YYZ", "YVR", "LHR", "CDG"],
            "region": ["NAM", "EUR"]
          }
        },
        "delivery": {
          "roles": ["FulfillmentCrew", "MasterDataRead", "ePODCapture", "FuelOrderCreate"],
          "attributes": {
            "station": ["YYZ", "YVR"],
            "region": ["NAM"]
          }
        },
        "refueler": {
          "roles": ["FuelOrderApprove", "ePODCapture", "MasterDataRead"],
          "attributes": {
            "station": ["YYZ", "YVR", "LHR", "CDG"],
            "region": ["NAM", "EUR"]
          }
        },
        "crew": {
          "roles": ["FuelOrderCreate", "MasterDataRead"],
          "attributes": {
            "station": ["*"],
            "region": ["*"]
          }
        },
        "finance": {
          "roles": ["FinanceController", "MasterDataRead", "InvoiceVerify", "InvoiceApprove", "FinancePost", "ReportView"]
        },
        "analyst": {
          "roles": ["MasterDataRead", "ReportView", "BurnDataView"]
        },
        "*": true
      }
    }
  },
  "build": {
    "target": "gen",
    "tasks": [
      {
        "for": "hana",
        "src": "db",
        "options": {
          "model": ["db", "srv", "app"]
        }
      },
      {
        "for": "node-cf",
        "src": "srv",
        "options": {
          "model": ["db", "srv", "app"]
        }
      }
    ]
  },
  "requires": {
    "db": {
      "kind": "sql"
    },
    "[production]": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "xsuaa"
      }
    }
  },
  "odata": {
    "version": "v4"
  },
  "log": {
    "levels": {
      "cds": "info"
    }
  },
  "features": {
    "odata_new_parser": true
  }
}
