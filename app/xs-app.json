{
    "welcomeFile": "/admin/index.html",
    "authenticationMethod": "route",
    "sessionTimeout": 60,
    "routes": [
        {
            "source": "^/admin/(.*)$",
            "target": "/admin/$1",
            "localDir": ".",
            "authenticationType": "none"
        },
        {
            "source": "^/operations/(.*)$",
            "target": "/operations/$1",
            "localDir": ".",
            "authenticationType": "none"
        },
        {
            "source": "^/planning/(.*)$",
            "target": "/planning/$1",
            "localDir": ".",
            "authenticationType": "none"
        },
        {
            "source": "^/fulfillment/(.*)$",
            "target": "/fulfillment/$1",
            "localDir": ".",
            "authenticationType": "none"
        },
        {
            "source": "^/invoicing/(.*)$",
            "target": "/invoicing/$1",
            "localDir": ".",
            "authenticationType": "none"
        },
        {
            "source": "^/odata/v4/(.*)$",
            "target": "/odata/v4/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": true
        },
        {
            "source": "^(.*)$",
            "target": "/$1",
            "localDir": ".",
            "authenticationType": "xsuaa"
        }
    ]
}
